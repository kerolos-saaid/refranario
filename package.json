{
  "name": "refranario",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot server/src/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy:api": "wrangler deploy",
    "deploy:api:prod": "wrangler deploy --env production",
    "d1:create": "wrangler d1 create senor-shabi-db",
    "d1:migrate": "wrangler d1 execute senor-shabi-db --local --file=./server/src/schema.sql",
    "d1:seed": "wrangler d1 execute senor-shabi-db --local --file=./server/src/seed.sql",
    "pages:deploy": "npm run build && npx wrangler pages deploy dist/client"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/bun": "latest",
    "@types/react": "19",
    "@types/react-dom": "19",
    "@vitejs/plugin-react": "^6.0.1",
    "wrangler": "^4.73.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/vite-dev-server": "^0.25.1",
    "autoprefixer": "^10.4.27",
    "hono": "^4.12.8",
    "postcss": "^8.5.8",
    "react": "19.2",
    "react-dom": "19.2",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^4.2.1",
    "vite": "^8.0.0"
  }
}
