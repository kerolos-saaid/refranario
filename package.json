{
  "name": "refranario",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --test-scheduled",
    "dev:client": "vite",
    "test:server": "bun test server/test",
    "test:e2e:server": "bun test server/test/e2e",
    "build": "vite build",
    "preview": "vite preview",
    "bump-sw": "node -e \"const fs=require('fs'); const f='client/public/sw.js'; let c=fs.readFileSync(f,'utf8'); const v=c.match(/senor-shabi-v(\\d+)/); if(v){c=c.replace(/senor-shabi-v\\d+/g,'senor-shabi-v'+(parseInt(v[1])+1)); fs.writeFileSync(f,c); console.log('Bumped to v'+(parseInt(v[1])+1));}\"",
    "deploy:api": "npm run bump-sw && wrangler deploy",
    "deploy:api:prod": "npm run bump-sw && wrangler deploy --env production",
    "d1:create": "wrangler d1 create senor-shabi-db",
    "d1:migrate": "wrangler d1 execute senor-shabi-db --local --file=./server/src/schema.sql",
    "d1:migrate:image-jobs": "wrangler d1 execute senor-shabi-db --local --file=./server/src/migrations/001_proverb_image_job_columns.sql",
    "d1:migrate:image-prompts": "wrangler d1 execute senor-shabi-db --local --file=./server/src/migrations/002_proverb_image_generation_prompt.sql",
    "d1:seed": "wrangler d1 execute senor-shabi-db --local --file=./server/src/seed.sql",
    "pages:deploy": "npm run bump-sw && npm run build && npx wrangler pages deploy dist/client"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/bun": "latest",
    "@types/react": "19",
    "@types/react-dom": "19",
    "@vitejs/plugin-react": "^6.0.1",
    "wrangler": "^4.73.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/vite-dev-server": "^0.25.1",
    "autoprefixer": "^10.4.27",
    "hono": "^4.12.8",
    "postcss": "^8.5.8",
    "react": "19.2",
    "react-dom": "19.2",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^4.2.1",
    "vite": "^8.0.0"
  }
}
